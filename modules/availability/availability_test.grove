module availability_test

test availability_create_and_update {
  run create {
    request {
      name: "create_availability",
      params: {
        user_id: "contractor-1",
        organization_id: "org-1",
        day_of_week: "monday",
        start_time: "09:00",
        end_time: "17:00"
      },
      meta: {
        id: "avail-1",
        by: "contractor-1",
        timestamp: 1700000000000,
        action_id: "cmd-create-avail"
      }
    }
    expect ok
    assert record.user_id == "contractor-1"
    assert record.organization_id == "org-1"
    assert record.day_of_week == "monday"
    assert record.start_time == "09:00"
    assert record.end_time == "17:00"
    assert record.status == "active"
    assert events.len == 1
    assert events[0].name == "availability_created"
  }

  run update {
    request {
      name: "update_availability",
      params: {
        start_time: "10:00",
        end_time: "18:00"
      },
      meta: {
        id: "avail-1",
        by: "contractor-1",
        timestamp: 1700000000100,
        action_id: "cmd-update-avail"
      }
    }
    expect ok
    assert record.start_time == "10:00"
    assert record.end_time == "18:00"
    assert events[0].name == "availability_updated"
  }
}

test availability_deactivate_and_reactivate {
  run create {
    request {
      name: "create_availability",
      params: {
        user_id: "contractor-2",
        day_of_week: "wednesday",
        start_time: "08:00",
        end_time: "16:00"
      },
      meta: {
        id: "avail-2",
        by: "contractor-2",
        timestamp: 1700000001000,
        action_id: "cmd-create-avail-2"
      }
    }
    expect ok
    assert record.status == "active"
  }

  run deactivate {
    request {
      name: "deactivate_availability",
      params: {},
      meta: {
        id: "avail-2",
        by: "contractor-2",
        timestamp: 1700000001100,
        action_id: "cmd-deactivate"
      }
    }
    expect ok
    assert record.status == "inactive"
    assert events[0].name == "availability_deactivated"
  }

  run reactivate {
    request {
      name: "activate_availability",
      params: {},
      meta: {
        id: "avail-2",
        by: "contractor-2",
        timestamp: 1700000001200,
        action_id: "cmd-activate"
      }
    }
    expect ok
    assert record.status == "active"
    assert events[0].name == "availability_activated"
  }
}

test cannot_deactivate_inactive {
  run create {
    request {
      name: "create_availability",
      params: {
        user_id: "contractor-3",
        day_of_week: "friday",
        start_time: "09:00",
        end_time: "12:00"
      },
      meta: {
        id: "avail-3",
        by: "contractor-3",
        timestamp: 1700000002000,
        action_id: "cmd-create-avail-3"
      }
    }
    expect ok
  }

  run deactivate {
    request {
      name: "deactivate_availability",
      params: {},
      meta: {
        id: "avail-3",
        by: "contractor-3",
        timestamp: 1700000002100,
        action_id: "cmd-deactivate-3"
      }
    }
    expect ok
  }

  run deactivate_again_fails {
    request {
      name: "deactivate_availability",
      params: {},
      meta: {
        id: "avail-3",
        by: "contractor-3",
        timestamp: 1700000002200,
        action_id: "cmd-deactivate-again"
      }
    }
    expect error "is_active"
  }
}

test cannot_activate_active {
  run create {
    request {
      name: "create_availability",
      params: {
        user_id: "contractor-4",
        day_of_week: "tuesday",
        start_time: "13:00",
        end_time: "17:00"
      },
      meta: {
        id: "avail-4",
        by: "contractor-4",
        timestamp: 1700000003000,
        action_id: "cmd-create-avail-4"
      }
    }
    expect ok
  }

  run activate_fails {
    request {
      name: "activate_availability",
      params: {},
      meta: {
        id: "avail-4",
        by: "contractor-4",
        timestamp: 1700000003100,
        action_id: "cmd-activate-active"
      }
    }
    expect error "is_inactive"
  }
}

test create_missing_user_fails {
  run bad_create {
    request {
      name: "create_availability",
      params: {
        user_id: "",
        day_of_week: "monday",
        start_time: "09:00",
        end_time: "17:00"
      },
      meta: {
        id: "avail-bad-user",
        by: "unknown",
        timestamp: 1700000004000,
        action_id: "cmd-bad-user"
      }
    }
    expect error "user_required"
  }
}

