test multiple_slots_per_day {
  run morning {
    request {
      name: "create_availability",
      params: {
        user_id: "contractor-7",
        organization_id: "org-7",
        day_of_week: "thursday",
        start_time: "08:00",
        end_time: "12:00"
      },
      meta: {
        id: "avail-morning",
        by: "contractor-7",
        timestamp: 1700000007000,
        action_id: "cmd-morning"
      }
    }
    expect ok
    assert record.start_time == "08:00"
    assert record.end_time == "12:00"
  }
}

test create_minimal_params {
  run create {
    request {
      name: "create_availability",
      params: {
        user_id: "contractor-8",
        day_of_week: "saturday",
        start_time: "10:00",
        end_time: "14:00"
      },
      meta: {
        id: "avail-minimal",
        by: "contractor-8",
        timestamp: 1700000008000,
        action_id: "cmd-minimal"
      }
    }
    expect ok
    assert record.user_id == "contractor-8"
    assert record.organization_id == ""
    assert record.day_of_week == "saturday"
    assert record.start_time == "10:00"
    assert record.end_time == "14:00"
    assert record.status == "active"
  }
}

