        start_time: "09:00",
        end_time: "17:00"
      },
      meta: {
        id: "avail-partial-start",
        by: "contractor-10",
        timestamp: 1700000010000,
        action_id: "cmd-create-ps"
      }
    }
    expect ok
  }

  run update_start {
    request {
      name: "update_availability",
      params: {
        start_time: "07:00"
      },
      meta: {
        id: "avail-partial-start",
        by: "contractor-10",
        timestamp: 1700000010100,
        action_id: "cmd-update-start"
      }
    }
    expect ok
    assert record.start_time == "07:00"
    assert events[0].name == "availability_updated"
  }
}

