test full_cycle_create_update_deactivate_reactivate {
  run create {
    request {
      name: "create_availability",
      params: {
        user_id: "contractor-12",
        organization_id: "org-12",
        day_of_week: "wednesday",
        start_time: "08:00",
        end_time: "12:00"
      },
      meta: {
        id: "avail-full-cycle",
        by: "contractor-12",
        timestamp: 1700000012000,
        action_id: "cmd-create-fc"
      }
    }
    expect ok
    assert record.status == "active"
  }

  run update {
    request {
      name: "update_availability",
      params: {
        start_time: "09:00",
        end_time: "13:00"
      },
      meta: {
        id: "avail-full-cycle",
        by: "contractor-12",
        timestamp: 1700000012100,
        action_id: "cmd-update-fc"
      }
    }
    expect ok
    assert record.start_time == "09:00"
    assert record.end_time == "13:00"
  }

  run deactivate {
    request {
      name: "deactivate_availability",
      params: {},
      meta: {
        id: "avail-full-cycle",
        by: "contractor-12",
        timestamp: 1700000012200,
        action_id: "cmd-deactivate-fc"
      }
    }
    expect ok
    assert record.status == "inactive"
  }

  run reactivate {
    request {
      name: "activate_availability",
      params: {},
      meta: {
        id: "avail-full-cycle",
        by: "contractor-12",
        timestamp: 1700000012300,
        action_id: "cmd-activate-fc"
      }
    }
    expect ok
    assert record.status == "active"
  }

  run deactivate_again {
    request {
      name: "deactivate_availability",
      params: {},
      meta: {
        id: "avail-full-cycle",
        by: "contractor-12",
        timestamp: 1700000012400,
        action_id: "cmd-deactivate-fc2"
      }
    }
    expect ok
    assert record.status == "inactive"
  }
}

test create_event_fields {
  run create {
    request {
      name: "create_availability",
      params: {
        user_id: "contractor-13",
        organization_id: "org-13",
        day_of_week: "friday",
        start_time: "07:00",
        end_time: "15:00"
      },
      meta: {
        id: "avail-event-fields",
        by: "contractor-13",
        timestamp: 1700000013000,
        action_id: "cmd-create-ef"
      }
    }
    expect ok
    assert events.len == 1
    assert events[0].name == "availability_created"
    assert events[0].data.user_id == "contractor-13"
    assert events[0].data.organization_id == "org-13"
    assert events[0].data.day_of_week == "friday"
    assert events[0].data.start_time == "07:00"
    assert events[0].data.end_time == "15:00"
    assert events[0].data.status == "active"
  }
}
