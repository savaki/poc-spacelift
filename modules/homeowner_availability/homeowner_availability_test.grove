test cannot_book_withdrawn_window {
  run submit {
    request {
      name: "submit_availability",
      params: {
        project_id: "proj-6",
        available_date: "2024-04-22",
        start_time: "10:00",
        end_time: "14:00"
      },
      meta: {
        id: "ha-book-withdrawn",
        by: "homeowner-6",
        timestamp: 1700000005000,
        action_id: "cmd-submit-bw"
      }
    }
    expect ok
  }

  run withdraw {
    request {
      name: "withdraw_availability",
      params: {},
      meta: {
        id: "ha-book-withdrawn",
        by: "homeowner-6",
        timestamp: 1700000005100,
        action_id: "cmd-withdraw-bw"
      }
    }
    expect ok
  }

  run book_fails {
    request {
      name: "mark_booked",
      params: {
        visit_id: "visit-999"
      },
      meta: {
        id: "ha-book-withdrawn",
        by: "consultant-6",
        timestamp: 1700000005200,
        action_id: "cmd-book-bw"
      }
    }
    expect error "is_open"
  }
}

