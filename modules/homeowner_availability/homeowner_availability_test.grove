module homeowner_availability_test

test submit_and_book_lifecycle {
  run submit {
    request {
      name: "submit_availability",
      params: {
        project_id: "proj-1",
        homeowner_name: "Jane Smith",
        homeowner_email: "jane@example.com",
        homeowner_phone: "555-0100",
        available_date: "2024-04-15",
        start_time: "09:00",
        end_time: "14:00",
        notes: "Prefer morning if possible"
      },
      meta: {
        id: "ha-1",
        by: "homeowner-1",
        timestamp: 1700000000000,
        action_id: "cmd-submit-ha"
      }
    }
    expect ok
    assert record.project_id == "proj-1"
    assert record.homeowner_name == "Jane Smith"
    assert record.homeowner_email == "jane@example.com"
    assert record.available_date == "2024-04-15"
    assert record.start_time == "09:00"
    assert record.end_time == "14:00"
    assert record.status == "open"
    assert record.visit_id == ""
    assert record.notes == "Prefer morning if possible"
    assert events.len == 1
    assert events[0].name == "homeowner_availability_submitted"
  }

  run book {
    request {
      name: "mark_booked",
      params: {
        visit_id: "visit-101"
      },
      meta: {
        id: "ha-1",
        by: "consultant-1",
        timestamp: 1700000000100,
        action_id: "cmd-book-ha"
      }
    }
    expect ok
    assert record.status == "booked"
    assert record.visit_id == "visit-101"
    assert events[0].name == "homeowner_availability_booked"
  }
}

test submit_multiple_windows {
  run window_1 {
    request {
      name: "submit_availability",
      params: {
        project_id: "proj-2",
        homeowner_name: "Bob Jones",
        available_date: "2024-04-16",
