test submit_minimal_params_defaults {
  run submit {
    request {
      name: "submit_availability",
      params: {
        project_id: "proj-23",
        available_date: "2024-06-01",
        start_time: "09:00",
        end_time: "17:00"
      },
      meta: {
        id: "ha-defaults",
        by: "homeowner-23",
        timestamp: 1700000022000,
        action_id: "cmd-submit-defaults"
      }
    }
    expect ok
    assert record.project_id == "proj-23"
    assert record.homeowner_name == ""
    assert record.homeowner_email == ""
    assert record.homeowner_phone == ""
    assert record.available_date == "2024-06-01"
    assert record.start_time == "09:00"
    assert record.end_time == "17:00"
    assert record.status == "open"
    assert record.visit_id == ""
    assert record.notes == ""
  }
}

test create_event_fields {
  run submit {
    request {
      name: "submit_availability",
      params: {
        project_id: "proj-24",
        homeowner_name: "Event Test",
        homeowner_email: "event@example.com",
        homeowner_phone: "555-2400",
        available_date: "2024-06-05",
        start_time: "10:00",
        end_time: "14:00",
        notes: "Back gate is open"
      },
      meta: {
        id: "ha-event-fields",
        by: "homeowner-24",
        timestamp: 1700000023000,
        action_id: "cmd-submit-ef"
      }
    }
    expect ok
    assert events.len == 1
    assert events[0].name == "homeowner_availability_submitted"
    assert events[0].data.project_id == "proj-24"
    assert events[0].data.homeowner_name == "Event Test"
    assert events[0].data.homeowner_email == "event@example.com"
    assert events[0].data.homeowner_phone == "555-2400"
    assert events[0].data.available_date == "2024-06-05"
    assert events[0].data.start_time == "10:00"
    assert events[0].data.end_time == "14:00"
    assert events[0].data.status == "open"
    assert events[0].data.visit_id == ""
    assert events[0].data.notes == "Back gate is open"
  }
}

test update_then_book {
  run submit {
    request {
      name: "submit_availability",
      params: {
        project_id: "proj-25",
        homeowner_name: "Update Book Test",
        available_date: "2024-06-10",
        start_time: "08:00",
        end_time: "12:00"
      },
      meta: {
        id: "ha-update-book",
        by: "homeowner-25",
        timestamp: 1700000024000,
        action_id: "cmd-submit-ub2"
      }
    }
    expect ok
  }

  run update {
    request {
      name: "update_availability",
      params: {
        start_time: "09:00",
        end_time: "13:00",
        notes: "Updated window"
      },
      meta: {
        id: "ha-update-book",
        by: "homeowner-25",
        timestamp: 1700000024100,
        action_id: "cmd-update-ub2"
      }
    }
    expect ok
    assert record.start_time == "09:00"
    assert record.end_time == "13:00"
    assert record.notes == "Updated window"
  }

  run book {
    request {
      name: "mark_booked",
      params: {
        visit_id: "visit-800"
      },
      meta: {
        id: "ha-update-book",
        by: "consultant-25",
        timestamp: 1700000024200,
        action_id: "cmd-book-ub2"
      }
    }
    expect ok
    assert record.status == "booked"
    assert record.visit_id == "visit-800"
    assert record.start_time == "09:00"
    assert record.end_time == "13:00"
  }
}
