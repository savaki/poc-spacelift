      },
      meta: {
        id: "ha-multi-1",
        by: "homeowner-2",
        timestamp: 1700000001000,
        action_id: "cmd-submit-multi-1"
      }
    }
    expect ok
    assert record.status == "open"
    assert record.available_date == "2024-04-16"
  }
}

test update_open_window {
  run submit {
    request {
      name: "submit_availability",
      params: {
        project_id: "proj-3",
        available_date: "2024-04-18",
        start_time: "08:00",
        end_time: "12:00"
      },
      meta: {
        id: "ha-update",
        by: "homeowner-3",
        timestamp: 1700000002000,
        action_id: "cmd-submit-update"
      }
    }
    expect ok
  }

  run update {
    request {
      name: "update_availability",
      params: {
        start_time: "10:00",
        end_time: "15:00",
        notes: "Changed my schedule"
      },
      meta: {
        id: "ha-update",
        by: "homeowner-3",
        timestamp: 1700000002100,
        action_id: "cmd-update-ha"
      }
    }
    expect ok
    assert record.start_time == "10:00"
    assert record.end_time == "15:00"
    assert record.notes == "Changed my schedule"
    assert events[0].name == "homeowner_availability_updated"
  }
}

test withdraw_open_window {
