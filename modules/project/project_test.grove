test invalid_project_type_fails {
  run bad_type {
    request {
      name: "create_project",
      params: {
        project_type: "swimming_pool"
      },
      meta: {
        id: "proj-bad",
        by: "consultant-1",
        timestamp: 1700000003000,
        action_id: "cmd-bad-type"
      }
    }
    expect error "valid_project_type"
  }
}
