module referral_test

test referral_full_lifecycle {
  run send {
    request {
      name: "send_referral",
      params: {
        project_id: "proj-1",
        organization_id: "org-1",
        sender_id: "user-consultant-1",
        consultant_notes: "Great fit for this project"
      },
      meta: {
        id: "ref-1",
        by: "consultant-1",
        timestamp: 1700000000000,
        action_id: "cmd-send-ref"
      }
    }
    expect ok
    assert record.project_id == "proj-1"
    assert record.organization_id == "org-1"
    assert record.sender_id == "user-consultant-1"
    assert record.status == "sent"
    assert record.consultant_notes == "Great fit for this project"
    assert record.contractor_notes == ""
    assert record.meeting_date == ""
    assert events.len == 1
    assert events[0].name == "referral_sent"
  }

  run view {
    request {
      name: "mark_viewed",
      params: {},
      meta: {
        id: "ref-1",
        by: "contractor-1",
        timestamp: 1700000000100,
        action_id: "cmd-view-ref"
      }
    }
    expect ok
    assert record.status == "viewed"
    assert events[0].name == "referral_viewed"
  }

  run accept {
    request {
      name: "accept_referral",
      params: {
        contractor_notes: "We can start next month"
      },
      meta: {
        id: "ref-1",
        by: "contractor-1",
        timestamp: 1700000000200,
        action_id: "cmd-accept-ref"
      }
    }
    expect ok
    assert record.status == "accepted"
    assert record.contractor_notes == "We can start next month"
    assert events[0].name == "referral_accepted"
  }

  run schedule_meeting {
    request {
      name: "schedule_meeting",
      params: {
        meeting_date: "2024-03-15T10:00:00Z",
        meeting_notes: "Introduction call with homeowner"
      },
      meta: {
        id: "ref-1",
        by: "consultant-1",
        timestamp: 1700000000300,
        action_id: "cmd-schedule"
      }
    }
    expect ok
    assert record.status == "scheduled"
    assert record.meeting_date == "2024-03-15T10:00:00Z"
    assert record.meeting_notes == "Introduction call with homeowner"
    assert events[0].name == "meeting_scheduled"
  }

  run confirm {
    request {
      name: "confirm_connection",
      params: {},
      meta: {
        id: "ref-1",
        by: "consultant-1",
        timestamp: 1700000000400,
        action_id: "cmd-confirm"
      }
    }
    expect ok
    assert record.status == "connected"
    assert events[0].name == "connection_confirmed"
  }
}

test referral_decline_from_sent {
  run send {
    request {
      name: "send_referral",
      params: {
        project_id: "proj-2",
        organization_id: "org-2",
        sender_id: "user-consultant-2"
      },
      meta: {
        id: "ref-decline-sent",
        by: "consultant-2",
        timestamp: 1700000001000,
        action_id: "cmd-send-decline"
      }
    }
    expect ok
    assert record.status == "sent"
  }

  run decline {
    request {
      name: "decline_referral",
      params: {
        contractor_notes: "Too far from our service area"
      },
      meta: {
        id: "ref-decline-sent",
        by: "contractor-2",
        timestamp: 1700000001100,
        action_id: "cmd-decline-sent"
      }
    }
    expect ok
    assert record.status == "declined"
    assert record.contractor_notes == "Too far from our service area"
    assert events[0].name == "referral_declined"
  }
}

