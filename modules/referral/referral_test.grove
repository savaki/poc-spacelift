test accept_from_sent_directly {
  run send {
    request {
      name: "send_referral",
      params: {
        project_id: "proj-4",
        organization_id: "org-4",
        sender_id: "user-consultant-4"
      },
      meta: {
        id: "ref-accept-direct",
        by: "consultant-4",
        timestamp: 1700000003000,
        action_id: "cmd-send-direct"
      }
    }
    expect ok
  }

  run accept_without_view {
    request {
      name: "accept_referral",
      params: {
        contractor_notes: "Happy to help"
      },
      meta: {
        id: "ref-accept-direct",
        by: "contractor-4",
        timestamp: 1700000003100,
        action_id: "cmd-accept-direct"
      }
    }
    expect ok
    assert record.status == "accepted"
  }
}

test save_contractor_notes {
  run send {
    request {
      name: "send_referral",
      params: {
        project_id: "proj-5",
        organization_id: "org-5",
        sender_id: "user-consultant-5"
      },
      meta: {
        id: "ref-notes",
        by: "consultant-5",
        timestamp: 1700000004000,
        action_id: "cmd-send-notes"
      }
    }
    expect ok
  }

  run save_notes {
    request {
      name: "save_contractor_notes",
      params: {
        contractor_notes: "Reviewed the project scope"
      },
      meta: {
        id: "ref-notes",
        by: "contractor-5",
        timestamp: 1700000004100,
        action_id: "cmd-save-notes"
      }
    }
    expect ok
    assert record.contractor_notes == "Reviewed the project scope"
    assert events[0].name == "contractor_notes_saved"
  }
}

test cannot_view_non_sent {
  run send {
    request {
      name: "send_referral",
      params: {
        project_id: "proj-6",
        organization_id: "org-6",
        sender_id: "user-consultant-6"
      },
      meta: {
        id: "ref-view-fail",
        by: "consultant-6",
        timestamp: 1700000005000,
        action_id: "cmd-send-view"
      }
    }
    expect ok
  }

  run view {
    request {
      name: "mark_viewed",
      params: {},
      meta: {
        id: "ref-view-fail",
        by: "contractor-6",
        timestamp: 1700000005100,
        action_id: "cmd-view-ok"
      }
    }
    expect ok
  }

  run view_again_fails {
    request {
      name: "mark_viewed",
      params: {},
      meta: {
        id: "ref-view-fail",
        by: "contractor-6",
        timestamp: 1700000005200,
        action_id: "cmd-view-again"
      }
    }
    expect error "is_sent"
  }
}

test cannot_accept_declined {
  run send {
    request {
      name: "send_referral",
      params: {
        project_id: "proj-7",
        organization_id: "org-7",
        sender_id: "user-consultant-7"
      },
      meta: {
        id: "ref-accept-declined",
        by: "consultant-7",
        timestamp: 1700000006000,
        action_id: "cmd-send-ad"
      }
    }
    expect ok
  }

  run decline {
    request {
      name: "decline_referral",
      params: {},
      meta: {
        id: "ref-accept-declined",
        by: "contractor-7",
        timestamp: 1700000006100,
        action_id: "cmd-decline-ad"
      }
    }
    expect ok
  }

  run accept_fails {
    request {
      name: "accept_referral",
      params: {},
      meta: {
        id: "ref-accept-declined",
        by: "contractor-7",
        timestamp: 1700000006200,
        action_id: "cmd-accept-ad"
      }
    }
    expect error "can_accept"
  }
}

