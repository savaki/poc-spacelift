test send_referral_missing_project_fails {
  run bad_send {
    request {
      name: "send_referral",
      params: {
        project_id: "",
        organization_id: "org-10",
        sender_id: "user-10"
      },
      meta: {
        id: "ref-bad-proj",
        by: "consultant-10",
        timestamp: 1700000009000,
        action_id: "cmd-bad-proj"
      }
    }
    expect error "project_required"
  }
}

