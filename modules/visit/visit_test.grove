test create_event_fields {
  run request {
    request {
      name: "request_visit",
      params: {
        project_id: "proj-30",
        organization_id: "org-30",
        contractor_id: "contractor-30",
        referral_id: "ref-30",
        homeowner_name: "Test Owner",
        homeowner_email: "test@example.com",
        homeowner_phone: "555-3000",
        scheduled_date: "2024-08-01",
        start_time: "09:00",
        end_time: "10:00",
        visit_type: "estimate",
        location_street: "456 Elm St",
        location_city: "Portland",
        location_state: "OR",
        location_zip: "97201",
        homeowner_notes: "Ring doorbell twice"
      },
      meta: {
        id: "visit-event-fields",
        by: "consultant-30",
        timestamp: 1700000029000,
        action_id: "cmd-req-ef"
      }
    }
    expect ok
    assert events.len == 1
    assert events[0].name == "visit_requested"
    assert events[0].payload.project_id == "proj-30"
    assert events[0].payload.organization_id == "org-30"
    assert events[0].payload.contractor_id == "contractor-30"
    assert events[0].payload.referral_id == "ref-30"
    assert events[0].payload.homeowner_name == "Test Owner"
    assert events[0].payload.scheduled_date == "2024-08-01"
    assert events[0].payload.start_time == "09:00"
    assert events[0].payload.end_time == "10:00"
    assert events[0].payload.visit_type == "estimate"
    assert events[0].payload.status == "requested"
    assert events[0].payload.location_street == "456 Elm St"
    assert events[0].payload.homeowner_notes == "Ring doorbell twice"
    assert events[0].payload.contractor_notes == ""
    assert events[0].payload.cancellation_reason == ""
  }
}

test notes_update_on_completed_visit {
  run request {
    request {
      name: "request_visit",
      params: {
        project_id: "proj-31",
        contractor_id: "contractor-31",
        scheduled_date: "2024-08-05",
        start_time: "10:00"
      },
      meta: {
        id: "visit-notes-done",
        by: "consultant-31",
        timestamp: 1700000030000,
        action_id: "cmd-req-nd"
      }
    }
    expect ok
  }

  run confirm {
    request {
      name: "confirm_visit",
      params: {},
      meta: {
        id: "visit-notes-done",
        by: "contractor-31",
        timestamp: 1700000030100,
        action_id: "cmd-confirm-nd"
      }
    }
    expect ok
  }

  run start {
    request {
      name: "start_visit",
      params: {},
      meta: {
        id: "visit-notes-done",
        by: "contractor-31",
        timestamp: 1700000030200,
        action_id: "cmd-start-nd"
      }
    }
    expect ok
  }

  run complete {
    request {
      name: "complete_visit",
      params: {},
      meta: {
        id: "visit-notes-done",
        by: "contractor-31",
        timestamp: 1700000030300,
        action_id: "cmd-complete-nd"
      }
    }
    expect ok
    assert record.status == "completed"
  }

  run add_homeowner_notes {
    request {
      name: "update_homeowner_notes",
      params: {
        homeowner_notes: "Great visit, very professional"
      },
      meta: {
        id: "visit-notes-done",
        by: "homeowner-31",
        timestamp: 1700000030400,
        action_id: "cmd-ho-notes-nd"
      }
    }
    expect ok
    assert record.homeowner_notes == "Great visit, very professional"
  }

  run add_contractor_notes {
    request {
      name: "update_contractor_notes",
      params: {
        contractor_notes: "Follow-up needed for plumbing"
      },
      meta: {
        id: "visit-notes-done",
        by: "contractor-31",
        timestamp: 1700000030500,
        action_id: "cmd-co-notes-nd"
      }
    }
    expect ok
    assert record.contractor_notes == "Follow-up needed for plumbing"
  }
}
