module visit_test

test visit_full_lifecycle {
  run request {
    request {
      name: "request_visit",
      params: {
        project_id: "proj-1",
        organization_id: "org-1",
        contractor_id: "contractor-1",
        referral_id: "ref-1",
        homeowner_name: "Jane Smith",
        homeowner_email: "jane@example.com",
        homeowner_phone: "555-0100",
        scheduled_date: "2024-04-15",
        start_time: "10:00",
        end_time: "11:00",
        visit_type: "initial_consultation",
        location_street: "123 Oak Ave",
        location_city: "Springfield",
        location_state: "IL",
        location_zip: "62701",
        homeowner_notes: "Please use the side entrance"
      },
      meta: {
        id: "visit-1",
        by: "consultant-1",
        timestamp: 1700000000000,
        action_id: "cmd-request-visit"
      }
    }
    expect ok
    assert record.project_id == "proj-1"
    assert record.organization_id == "org-1"
    assert record.contractor_id == "contractor-1"
    assert record.referral_id == "ref-1"
    assert record.homeowner_name == "Jane Smith"
    assert record.scheduled_date == "2024-04-15"
    assert record.start_time == "10:00"
    assert record.end_time == "11:00"
    assert record.status == "requested"
    assert record.location_street == "123 Oak Ave"
    assert record.homeowner_notes == "Please use the side entrance"
    assert record.contractor_notes == ""
    assert record.cancellation_reason == ""
    assert events.len == 1
    assert events[0].name == "visit_requested"
  }

  run confirm {
    request {
      name: "confirm_visit",
      params: {
        contractor_notes: "Will arrive 10 mins early"
      },
      meta: {
        id: "visit-1",
        by: "contractor-1",
        timestamp: 1700000000100,
        action_id: "cmd-confirm-visit"
      }
    }
    expect ok
    assert record.status == "confirmed"
    assert record.contractor_notes == "Will arrive 10 mins early"
    assert events[0].name == "visit_confirmed"
  }

  run start {
    request {
      name: "start_visit",
      params: {},
      meta: {
        id: "visit-1",
        by: "contractor-1",
        timestamp: 1700000000200,
        action_id: "cmd-start-visit"
      }
    }
    expect ok
    assert record.status == "in_progress"
    assert events[0].name == "visit_started"
  }

  run complete {
    request {
      name: "complete_visit",
      params: {
        contractor_notes: "Kitchen needs full remodel, estimate sent"
      },
      meta: {
        id: "visit-1",
        by: "contractor-1",
        timestamp: 1700000000300,
        action_id: "cmd-complete-visit"
      }
    }
    expect ok
    assert record.status == "completed"
    assert record.contractor_notes == "Kitchen needs full remodel, estimate sent"
    assert events[0].name == "visit_completed"
  }
}

test visit_cancel_from_requested {
  run request {
    request {
      name: "request_visit",
      params: {
        project_id: "proj-2",
        contractor_id: "contractor-2",
        scheduled_date: "2024-04-20",
        start_time: "14:00"
      },
      meta: {
        id: "visit-cancel-req",
        by: "consultant-2",
        timestamp: 1700000001000,
        action_id: "cmd-req-cancel"
      }
    }
    expect ok
    assert record.status == "requested"
  }

  run cancel {
    request {
      name: "cancel_visit",
      params: {
        cancellation_reason: "Homeowner scheduling conflict"
      },
      meta: {
        id: "visit-cancel-req",
        by: "consultant-2",
        timestamp: 1700000001100,
        action_id: "cmd-cancel-req"
      }
    }
    expect ok
    assert record.status == "cancelled"
    assert record.cancellation_reason == "Homeowner scheduling conflict"
    assert events[0].name == "visit_cancelled"
  }
}

test visit_cancel_from_confirmed {
