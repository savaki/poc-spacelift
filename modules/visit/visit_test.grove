test reschedule_then_confirm_full_cycle {
  run request {
    request {
      name: "request_visit",
      params: {
        project_id: "proj-22",
        contractor_id: "contractor-22",
        scheduled_date: "2024-07-01",
        start_time: "10:00",
        end_time: "11:00"
      },
      meta: {
        id: "visit-resched-cycle",
        by: "consultant-22",
        timestamp: 1700000021000,
        action_id: "cmd-req-rc"
      }
    }
    expect ok
  }

  run confirm {
    request {
      name: "confirm_visit",
      params: {},
      meta: {
        id: "visit-resched-cycle",
        by: "contractor-22",
        timestamp: 1700000021100,
        action_id: "cmd-confirm-rc"
      }
    }
    expect ok
    assert record.status == "confirmed"
  }

  run reschedule {
    request {
      name: "reschedule_visit",
      params: {
        scheduled_date: "2024-07-05",
        start_time: "15:00",
        end_time: "16:00"
      },
      meta: {
        id: "visit-resched-cycle",
        by: "consultant-22",
        timestamp: 1700000021200,
        action_id: "cmd-resched-rc"
      }
    }
    expect ok
    assert record.status == "requested"
    assert record.scheduled_date == "2024-07-05"
  }

  run reconfirm {
    request {
      name: "confirm_visit",
      params: {
        contractor_notes: "Confirmed for new date"
      },
      meta: {
        id: "visit-resched-cycle",
        by: "contractor-22",
        timestamp: 1700000021300,
        action_id: "cmd-reconfirm-rc"
      }
    }
    expect ok
    assert record.status == "confirmed"
    assert record.contractor_notes == "Confirmed for new date"
  }

  run start {
    request {
      name: "start_visit",
      params: {},
      meta: {
        id: "visit-resched-cycle",
        by: "contractor-22",
        timestamp: 1700000021400,
        action_id: "cmd-start-rc"
      }
    }
    expect ok
    assert record.status == "in_progress"
  }

  run complete {
    request {
      name: "complete_visit",
      params: {
        contractor_notes: "All done"
      },
      meta: {
        id: "visit-resched-cycle",
        by: "contractor-22",
        timestamp: 1700000021500,
        action_id: "cmd-complete-rc"
