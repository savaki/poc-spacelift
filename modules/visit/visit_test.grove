}

test visit_no_show {
  run request {
    request {
      name: "request_visit",
      params: {
        project_id: "proj-4",
        contractor_id: "contractor-4",
        scheduled_date: "2024-04-25",
        start_time: "11:00"
      },
      meta: {
        id: "visit-no-show",
        by: "consultant-4",
        timestamp: 1700000003000,
        action_id: "cmd-req-noshow"
      }
    }
    expect ok
  }

  run confirm {
    request {
      name: "confirm_visit",
      params: {},
      meta: {
        id: "visit-no-show",
        by: "contractor-4",
        timestamp: 1700000003100,
        action_id: "cmd-confirm-noshow"
      }
    }
    expect ok
  }

  run no_show {
    request {
      name: "mark_no_show",
      params: {
        contractor_notes: "Waited 30 minutes, homeowner did not arrive"
      },
      meta: {
        id: "visit-no-show",
        by: "contractor-4",
        timestamp: 1700000003200,
        action_id: "cmd-noshow"
      }
    }
    expect ok
    assert record.status == "no_show"
    assert record.contractor_notes == "Waited 30 minutes, homeowner did not arrive"
    assert events[0].name == "visit_no_show"
  }
}

test visit_reschedule {
  run request {
    request {
      name: "request_visit",
      params: {
        project_id: "proj-5",
        contractor_id: "contractor-5",
        scheduled_date: "2024-05-01",
        start_time: "10:00",
        end_time: "11:00"
      },
      meta: {
        id: "visit-resched",
        by: "consultant-5",
        timestamp: 1700000004000,
        action_id: "cmd-req-resched"
      }
    }
    expect ok
  }

  run confirm {
    request {
      name: "confirm_visit",
      params: {},
      meta: {
        id: "visit-resched",
        by: "contractor-5",
        timestamp: 1700000004100,
        action_id: "cmd-confirm-resched"
      }
    }
    expect ok
  }

  run reschedule {
    request {
      name: "reschedule_visit",
      params: {
        scheduled_date: "2024-05-08",
        start_time: "14:00",
        end_time: "15:00"
      },
      meta: {
        id: "visit-resched",
        by: "consultant-5",
        timestamp: 1700000004200,
        action_id: "cmd-reschedule"
      }
    }
    expect ok
    assert record.scheduled_date == "2024-05-08"
    assert record.start_time == "14:00"
    assert record.end_time == "15:00"
    assert record.status == "requested"
    assert events[0].name == "visit_rescheduled"
  }
}

test update_notes {
  run request {
    request {
      name: "request_visit",
      params: {
        project_id: "proj-6",
        contractor_id: "contractor-6",
        scheduled_date: "2024-05-10",
        start_time: "09:00"
      },
      meta: {
        id: "visit-notes",
        by: "consultant-6",
        timestamp: 1700000005000,
        action_id: "cmd-req-notes"
      }
    }
    expect ok
  }

  run homeowner_notes {
    request {
      name: "update_homeowner_notes",
      params: {
        homeowner_notes: "Dog is friendly but loud"
      },
      meta: {
        id: "visit-notes",
        by: "homeowner-6",
        timestamp: 1700000005100,
        action_id: "cmd-homeowner-notes"
      }
    }
    expect ok
    assert record.homeowner_notes == "Dog is friendly but loud"
    assert events[0].name == "homeowner_notes_updated"
  }

  run contractor_notes {
    request {
      name: "update_contractor_notes",
      params: {
        contractor_notes: "Bringing measuring equipment"
      },
      meta: {
        id: "visit-notes",
        by: "contractor-6",
        timestamp: 1700000005200,
        action_id: "cmd-contractor-notes"
      }
    }
    expect ok
    assert record.contractor_notes == "Bringing measuring equipment"
    assert events[0].name == "contractor_notes_updated"
  }
}

